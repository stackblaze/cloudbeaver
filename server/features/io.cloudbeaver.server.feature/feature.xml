<?xml version="1.0" encoding="UTF-8"?>
<feature
        id="io.cloudbeaver.server.feature"
        label="%featureName"
        version="26.1.0.qualifier"
        provider-name="%providerName"
        plugin="io.cloudbeaver.server">

    <description>
        %description
    </description>

    <copyright>
        %copyright
    </copyright>

    <requires>
        <import plugin="org.eclipse.core.runtime" version="3.7" match="greaterOrEqual"/>
        <!-- Equinox -->
        <import plugin="org.eclipse.equinox.common" version="0.0.0" match="greaterOrEqual"/>
        <import plugin="org.eclipse.equinox.event" version="0.0.0" match="greaterOrEqual"/>
        <import plugin="org.eclipse.equinox.preferences" version="0.0.0" match="greaterOrEqual"/>
        <import plugin="org.eclipse.equinox.registry" version="0.0.0" match="greaterOrEqual"/>
        <import plugin="org.eclipse.osgi.compatibility.state" version="0.0.0" match="greaterOrEqual"/>
        <!-- Main Equinox service provider -->
        <import plugin="org.apache.felix.scr" version="0.0.0" match="greaterOrEqual"/>
    </requires>

    <includes id="io.cloudbeaver.ws.feature" version="0.0.0"/>
    <includes id="org.jkiss.dbeaver.db.feature" version="0.0.0"/>

    <plugin id="org.jkiss.dbeaver.launcher" version="0.0.0"/>
    <plugin id="io.cloudbeaver.server" version="0.0.0"/>
    <plugin id="io.cloudbeaver.server.ce" version="0.0.0"/>
    <plugin id="io.cloudbeaver.service.admin" version="0.0.0"/>
    <plugin id="io.cloudbeaver.service.auth" version="0.0.0"/>
    <plugin id="io.cloudbeaver.service.data.transfer" version="0.0.0"/>
    <plugin id="io.cloudbeaver.service.metadata" version="0.0.0"/>
    <plugin id="io.cloudbeaver.service.fs" version="0.0.0"/>
    <plugin id="io.cloudbeaver.service.rm" version="0.0.0"/>
    <plugin id="io.cloudbeaver.service.rm.nio" version="0.0.0"/>

    <plugin id="io.cloudbeaver.service.security" version="0.0.0"/>
    <plugin id="io.cloudbeaver.service.ldap.auth" version="0.0.0"/>

    <!-- Extra plugins -->
    <plugin id="org.jkiss.dbeaver.data.office" version="0.0.0"/>
    <plugin id="org.jkiss.bundle.apache.poi" version="0.0.0"/>
    <plugin id="org.jkiss.dbeaver.net.ssh" version="0.0.0"/>
    <plugin id="org.jkiss.dbeaver.net.ssh.sshj" version="0.0.0"/>
    <plugin id="org.jkiss.bundle.graphql" version="0.0.0"/>
    <plugin id="org.jkiss.dbeaver.model.lsp" version="0.0.0"/>

</feature>
