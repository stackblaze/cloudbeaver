{
  "name": "@dbeaver/react-tests",
  "type": "module",
  "sideEffects": [],
  "exports": {
    ".": "./lib/index.js",
    "./*": "./lib/*.js"
  },
  "scripts": {
    "clear": "rimraf lib"
  },
  "files": [
    "package.json",
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
    "lib",
    "!lib/**/*.d.ts.map",
    "!lib/**/*.test.js",
    "!lib/**/*.test.d.ts",
    "!lib/**/*.test.d.ts.map",
    "!lib/**/*.test.js.map",
    "!lib/tests",
    "!.tsbuildinfo"
  ],
  "packageManager": "yarn@4.14.1",
  "devDependencies": {
    "@dbeaver/cli": "workspace:^",
    "@dbeaver/tsconfig": "workspace:^",
    "@testing-library/dom": "^10",
    "@testing-library/jest-dom": "^6",
    "@testing-library/react": "^16",
    "@types/node": "^22",
    "@types/ws": "^8",
    "rimraf": "^6",
    "typescript": "^5",
    "vitest": "^4",
    "ws": "^8"
  }
}
