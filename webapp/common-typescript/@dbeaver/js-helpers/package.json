{
  "name": "@dbeaver/js-helpers",
  "type": "module",
  "sideEffects": [],
  "exports": {
    ".": "./lib/index.js",
    "./*": "./lib/*.js"
  },
  "scripts": {
    "clear": "rimraf lib"
  },
  "files": [
    "package.json",
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
    "lib",
    "!lib/**/*.d.ts.map",
    "!lib/**/*.test.js",
    "!lib/**/*.test.d.ts",
    "!lib/**/*.test.d.ts.map",
    "!lib/**/*.test.js.map",
    "!lib/tests",
    "!.tsbuildinfo"
  ],
  "packageManager": "yarn@4.14.1",
  "devDependencies": {
    "@dbeaver/cli": "workspace:^",
    "@dbeaver/tsconfig": "workspace:^",
    "rimraf": "^6",
    "typescript": "^5",
    "vitest": "^4"
  },
  "dependencies": {
    "async-mutex": "^0",
    "color": "^5.0.2",
    "p-debounce": "^5",
    "p-memoize": "^8.0.0",
    "quick-lru": "^7.1.0"
  }
}
