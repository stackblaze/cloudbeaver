{
  "extends": "@cloudbeaver/tsconfig/tsconfig.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "lib",
    "tsBuildInfoFile": "lib/tsconfig.tsbuildinfo",
    "composite": true
  },
  "references": [
    {
      "path": "../../common-react/@dbeaver/ui-kit"
    },
    {
      "path": "../../common-typescript/@dbeaver/js-helpers"
    },
    {
      "path": "../core-administration"
    },
    {
      "path": "../core-app"
    },
    {
      "path": "../core-authentication"
    },
    {
      "path": "../core-blocks"
    },
    {
      "path": "../core-cli"
    },
    {
      "path": "../core-connections"
    },
    {
      "path": "../core-di"
    },
    {
      "path": "../core-events"
    },
    {
      "path": "../core-executor"
    },
    {
      "path": "../core-extensions"
    },
    {
      "path": "../core-localization"
    },
    {
      "path": "../core-projects"
    },
    {
      "path": "../core-resource"
    },
    {
      "path": "../core-settings"
    },
    {
      "path": "../core-storage"
    },
    {
      "path": "../core-ui"
    },
    {
      "path": "../core-utils"
    },
    {
      "path": "../core-view"
    }
  ],
  "include": [
    "__custom_mocks__/**/*",
    "src/**/*",
    "src/**/*.json",
    "src/**/*.css"
  ],
  "exclude": [
    "**/node_modules",
    "lib/**/*"
  ]
}
